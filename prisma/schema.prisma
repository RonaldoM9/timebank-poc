generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String  @id @default(cuid())
  name          String
  email         String  @unique
  password      String
  walletAddress String  @unique
  timeBalance   Float   @default(0)
  bio           String?
  avatar        String?
  city             String?
  postalCode       String?
  department       String?
  region           String?
  country          String  @default("France")
  serviceRadiusKm  Int?    @default(10)
  locationVisibility String @default("city")
  availableOnline  Boolean @default(false)
  createdAt        DateTime @default(now())

  transactionsFrom Transaction[] @relation("FromUser")
  transactionsTo   Transaction[] @relation("ToUser")
  services         Service[]
  clientBookings   Booking[]  @relation("ClientBookings")
  reputation       Float      @default(0)
  ratingsGiven     Rating[]   @relation("RatingsGiven")
  ratingsReceived  Rating[]   @relation("RatingsReceived")
  urgentRequests   UrgentRequest[] @relation("RequesterRequests")
  urgentOffers     UrgentOffer[]   @relation("ProviderOffers")
  proofsValidated  ProofOfCompletion[] @relation("ProofValidator")
  proofsProvided   ProofOfCompletion[] @relation("ProofProvider")
  badges           UserBadge[]
  xpEvents         UserXpEvent[]
  achievements     AchievementEvent[]
  userQuests       UserQuest[]
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String
  ratePerHour Int
  providerId  String
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  provider User      @relation(fields: [providerId], references: [id])
  bookings Booking[]
}

model Booking {
  id                 String    @id @default(cuid())
  serviceId          String
  clientId           String
  hours              Int
  totalTime          Int
  status             String    @default("pending")
  createdAt          DateTime  @default(now())
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?

  completionTokenHash    String?
  completionTokenExpiresAt DateTime?
  completionTokenMethod String? @default("qr_code")

  service      Service       @relation(fields: [serviceId], references: [id])
  client       User          @relation("ClientBookings", fields: [clientId], references: [id])
  transactions Transaction[]
  rating       Rating?
  proofOfCompletion ProofOfCompletion?
}

model ProofOfCompletion {
  id          String   @id @default(cuid())
  bookingId   String   @unique
  method      String   @default("qr_code")
  validatorId String
  providerId  String
  tokenHash   String
  status      String   @default("validated")
  createdAt   DateTime @default(now())

  booking   Booking @relation(fields: [bookingId], references: [id])
  validator User    @relation("ProofValidator", fields: [validatorId], references: [id])
  provider  User    @relation("ProofProvider", fields: [providerId], references: [id])
}

model Transaction {
  id        String   @id @default(cuid())
  fromId    String?
  toId      String?
  amount    Float
  type      String   // mint, escrow, release, refund, transfer
  status    String   @default("completed")
  bookingId String?
  createdAt DateTime @default(now())

  fromUser User?    @relation("FromUser", fields: [fromId], references: [id])
  toUser   User?    @relation("ToUser", fields: [toId], references: [id])
  booking  Booking? @relation(fields: [bookingId], references: [id])
}

model Rating {
  id        String   @id @default(cuid())
  bookingId String   @unique
  fromId    String
  toId      String
  score     Int
  comment   String?
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
  from    User    @relation("RatingsGiven", fields: [fromId], references: [id])
  to      User    @relation("RatingsReceived", fields: [toId], references: [id])
}

model UrgentRequest {
  id          String   @id @default(cuid())
  requesterId String
  title       String
  description String
  category    String
  city        String?
  department  String?
  region      String?
  online      Boolean  @default(false)
  urgency     String   @default("today")
  hours       Int
  ratePerHour Int
  totalTime   Int
  status      String   @default("open")
  createdAt   DateTime @default(now())
  expiresAt   DateTime?

  requester   User          @relation("RequesterRequests", fields: [requesterId], references: [id])
  offers      UrgentOffer[]
}

model UrgentOffer {
  id              String   @id @default(cuid())
  urgentRequestId String
  providerId      String
  message         String?
  status          String   @default("pending")
  createdAt       DateTime @default(now())

  urgentRequest UrgentRequest @relation(fields: [urgentRequestId], references: [id])
  provider      User          @relation("ProviderOffers", fields: [providerId], references: [id])
}

// ─── Lot 10 — Gamification ────────────────────────────────────────────────

model Badge {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String
  category    String   @default("general")
  icon        String   @default("award")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  userBadges UserBadge[]
  quests     Quest[]   @relation("QuestBadge")

  @@map("Badge")
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@map("UserBadge")
}

model UserXpEvent {
  id          String   @id @default(cuid())
  userId      String
  type        String
  points      Int
  sourceType  String?
  sourceId    String?
  description String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("UserXpEvent")
}

model AchievementEvent {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  description String?
  metadata    String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("AchievementEvent")
}

model Quest {
  id          String   @id @default(cuid())
  code        String   @unique
  title       String
  description String
  targetType  String    // missions_completed, time_donated, ratings_received, profile_complete, categories_explored
  targetValue Int
  rewardXp    Int      @default(0)
  badgeCode   String?
  badge       Badge?   @relation("QuestBadge", fields: [badgeCode], references: [code])
  isActive    Boolean  @default(true)
  repeatable  Boolean  @default(false)
  createdAt   DateTime @default(now())

  userQuests UserQuest[]

  @@map("Quest")
}

model UserQuest {
  id          String    @id @default(cuid())
  userId      String
  questId     String
  progress    Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  quest Quest @relation(fields: [questId], references: [id])

  user  User  @relation(fields: [userId], references: [id])

  @@unique([userId, questId])
  @@map("UserQuest")
}
