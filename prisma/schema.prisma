generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String  @id @default(cuid())
  name          String
  email         String  @unique
  password      String
  walletAddress String  @unique
  timeBalance   Float   @default(0)
  createdAt     DateTime @default(now())

  transactionsFrom Transaction[] @relation("FromUser")
  transactionsTo   Transaction[] @relation("ToUser")
  services         Service[]
  clientBookings   Booking[]  @relation("ClientBookings")
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String
  ratePerHour Int
  providerId  String
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  provider User      @relation(fields: [providerId], references: [id])
  bookings Booking[]
}

model Booking {
  id                 String    @id @default(cuid())
  serviceId          String
  clientId           String
  hours              Int
  totalTime          Int
  status             String    @default("pending")
  createdAt          DateTime  @default(now())
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?

  service      Service       @relation(fields: [serviceId], references: [id])
  client       User          @relation("ClientBookings", fields: [clientId], references: [id])
  transactions Transaction[]
}

model Transaction {
  id        String   @id @default(cuid())
  fromId    String?
  toId      String?
  amount    Float
  type      String   // mint, escrow, release, refund, transfer
  status    String   @default("completed")
  bookingId String?
  createdAt DateTime @default(now())

  fromUser User?    @relation("FromUser", fields: [fromId], references: [id])
  toUser   User?    @relation("ToUser", fields: [toId], references: [id])
  booking  Booking? @relation(fields: [bookingId], references: [id])
}
