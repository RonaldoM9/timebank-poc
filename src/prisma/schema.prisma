generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String  @id @default(cuid())
  name          String
  email         String  @unique
  password      String
  walletAddress String  @unique
  timeBalance   Float   @default(0)
  bio           String?
  avatar        String?
  city             String?
  postalCode       String?
  department       String?
  region           String?
  country          String  @default("France")
  serviceRadiusKm  Int?    @default(10)
  locationVisibility String @default("city")
  availableOnline  Boolean @default(false)
  createdAt        DateTime @default(now())

  transactionsFrom Transaction[] @relation("FromUser")
  transactionsTo   Transaction[] @relation("ToUser")
  services         Service[]
  clientBookings   Booking[]  @relation("ClientBookings")
  reputation       Float      @default(0)
  ratingsGiven     Rating[]   @relation("RatingsGiven")
  ratingsReceived  Rating[]   @relation("RatingsReceived")
  urgentRequests   UrgentRequest[] @relation("RequesterRequests")
  urgentOffers     UrgentOffer[]   @relation("ProviderOffers")
  proofsValidated  ProofOfCompletion[] @relation("ProofValidator")
  proofsProvided   ProofOfCompletion[] @relation("ProofProvider")
  badges           UserBadge[]
  availabilitySlots AvailabilitySlot[]
  xpEvents         UserXpEvent[]
  achievements     AchievementEvent[]
  userQuests       UserQuest[]
  heroPassport     HeroPassport?
  role             String   @default("USER")

  communityPotDonations CommunityPotTransaction[]
  communityPotRequests   CommunityPotRequest[]
  communityPotDecisions  CommunityPotRequest[] @relation("DecidedBy")

  collectiveMissions         CollectiveMission[]          @relation("CollectiveMissionOrganizer")
  collectiveMissionParticipants CollectiveMissionParticipant[]

  facilitatorNotes FacilitatorNote[]
  matchRecommendations MatchRecommendation[]
  matchFeedbacks MatchFeedback[]

  // ─── Lot 22 — Organisations ──────────────────────────────────────
  organizationsCreated     Organization[]         @relation("OrganizationCreator")
  organizationMemberships  OrganizationMember[]

  // ─── Lot 24 — Programmes ─────────────────────────────────────────
  programParticipations ProgramParticipant[]
  createdPrograms       OrganizationProgram[] @relation("ProgramCreator")

  // ─── End User ────────────────────────────────────────────────────
}

model HeroPassport {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  bio           String?
  offeredSkills String?
  wantedHelp    String?
  motivations   String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("HeroPassport")
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String
  ratePerHour Int
  providerId  String
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  provider User      @relation(fields: [providerId], references: [id])
  bookings Booking[]

  // ─── Lot 18 — Missions Solidaires ─────────────────────────────────
  isSolidarityMission  Boolean @default(false)
  solidarityCategory   String?
  solidarityStatus     String  @default("CLASSIC")
  solidarityReason     String?

  // ─── Lot 22 — Organisation rattachée ─────────────────────────────
  organizationId String?
}

model Booking {
  id                 String    @id @default(cuid())
  serviceId          String
  clientId           String
  hours              Int
  totalTime          Int
  status             String    @default("pending")
  createdAt          DateTime  @default(now())
  startAt            DateTime?
  endAt              DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?

  completionTokenHash    String?
  completionTokenExpiresAt DateTime?
  completionTokenMethod String? @default("qr_code")

  service      Service       @relation(fields: [serviceId], references: [id])
  client       User          @relation("ClientBookings", fields: [clientId], references: [id])
  transactions Transaction[]
  rating       Rating?
  proofOfCompletion ProofOfCompletion?

  lastMessageAt DateTime?

  messages BookingMessage[]

  fundedByCommunityPot Boolean @default(false)
  communityPotAmount   Int     @default(0)
}

model ProofOfCompletion {
  id          String   @id @default(cuid())
  bookingId   String   @unique
  method      String   @default("qr_code")
  validatorId String
  providerId  String
  tokenHash   String
  status      String   @default("validated")
  createdAt   DateTime @default(now())

  booking   Booking @relation(fields: [bookingId], references: [id])
  validator User    @relation("ProofValidator", fields: [validatorId], references: [id])
  provider  User    @relation("ProofProvider", fields: [providerId], references: [id])
}

model Transaction {
  id        String   @id @default(cuid())
  fromId    String?
  toId      String?
  amount    Float
  type      String   // mint, escrow, release, refund, transfer
  status    String   @default("completed")
  bookingId String?
  createdAt DateTime @default(now())

  fromUser User?    @relation("FromUser", fields: [fromId], references: [id])
  toUser   User?    @relation("ToUser", fields: [toId], references: [id])
  booking  Booking? @relation(fields: [bookingId], references: [id])
}

model Rating {
  id        String   @id @default(cuid())
  bookingId String   @unique
  fromId    String
  toId      String
  score     Int
  comment   String?
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
  from    User    @relation("RatingsGiven", fields: [fromId], references: [id])
  to      User    @relation("RatingsReceived", fields: [toId], references: [id])
}

model UrgentRequest {
  id          String   @id @default(cuid())
  requesterId String
  title       String
  description String
  category    String
  city        String?
  department  String?
  region      String?
  online      Boolean  @default(false)
  urgency     String   @default("today")
  hours       Int
  ratePerHour Int
  totalTime   Int
  status      String   @default("open")
  createdAt   DateTime @default(now())
  expiresAt   DateTime?

  requester   User          @relation("RequesterRequests", fields: [requesterId], references: [id])
  offers      UrgentOffer[]
}

model UrgentOffer {
  id              String   @id @default(cuid())
  urgentRequestId String
  providerId      String
  message         String?
  status          String   @default("pending")
  createdAt       DateTime @default(now())

  urgentRequest UrgentRequest @relation(fields: [urgentRequestId], references: [id])
  provider      User          @relation("ProviderOffers", fields: [providerId], references: [id])
}

// ─── Lot 17 — Community Pot / Pot Commun TIME ────────────────────────────────

model CommunityPot {
  id        String   @id @default(cuid())
  name      String   @default("Pot commun TimeHeroes")
  balance   Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions CommunityPotTransaction[]

  requests CommunityPotRequest[]
}

model CommunityPotTransaction {
  id        String   @id @default(cuid())
  potId     String
  pot       CommunityPot @relation(fields: [potId], references: [id], onDelete: Cascade)

  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  bookingId String?
  amount    Int
  type      String   // DONATION, FUNDING, ADJUSTMENT
  reason    String?

  createdAt DateTime @default(now())

  @@index([potId])
  @@index([userId])
  @@index([type])
  @@map("CommunityPotTransaction")
}

// ─── Lot 17 bis — Facilitator / Gardien des TIME ──────────────────────────

model CommunityPotRequest {
  id        String   @id @default(cuid())
  potId     String
  pot       CommunityPot @relation(fields: [potId], references: [id], onDelete: Cascade)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  bookingId String?
  amount    Int
  reason    String?
  message   String?

  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  decidedById String?
  decidedBy   User?    @relation("DecidedBy", fields: [decidedById], references: [id])
  decidedAt   DateTime?
  decisionNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([potId])
  @@index([userId])
  @@index([status])
  @@map("CommunityPotRequest")
}

// ─── End Lot 17 bis ───────────────────────────────────────────────────────

// ─── Lot 20 — Facilitator Dashboard v2 / Intelligence réseau ─────────────────

model FacilitatorNetworkAlert {
  id                  String   @id @default(cuid())

  type                String
  severity            String
  status              String   @default("OPEN")

  title               String
  description         String?
  recommendedAction   String?

  entityType          String?
  entityId            String?

  assignedToId        String?
  resolvedById        String?
  resolvedAt          DateTime?
  resolutionNote      String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([type])
  @@index([severity])
  @@index([status])
  @@index([entityType, entityId])
  @@map("FacilitatorNetworkAlert")
}

model FacilitatorNote {
  id          String   @id @default(cuid())

  authorId    String
  entityType  String
  entityId    String

  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User     @relation(fields: [authorId], references: [id])

  @@index([entityType, entityId])
  @@index([authorId])
  @@map("FacilitatorNote")
}

// ─── End Lot 20 ───────────────────────────────────────────────────────────

// ─── Lot 19 — Missions collectives / Co-production ─────────────────────────

model CollectiveMission {
  id              String   @id @default(cuid())

  title           String
  description     String
  type            String   // ONE_TO_MANY | MANY_TO_ONE | MANY_TO_MANY | ORG_TO_MANY
  category        String?
  status          String   @default("OPEN") // OPEN | FULL | IN_PROGRESS | ATTENDANCE_PENDING | COMPLETED | CANCELLED

  organizerId     String
  facilitatorId   String?

  city            String?
  department      String?
  region          String?
  locationLabel   String?
  online          Boolean  @default(false)

  startsAt        DateTime?
  endsAt          DateTime?
  durationHours   Int      // en heures entières

  minParticipants Int      @default(1)
  maxParticipants Int

  fundingSource   String   @default("NONE") // NONE | COMMUNITY_POT
  communityPotAmount Int   @default(0)

  isSolidarity      Boolean @default(false)
  solidarityCategory String?
  solidarityReason  String?

  completedAt     DateTime?
  cancelledAt     DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organizer       User              @relation("CollectiveMissionOrganizer", fields: [organizerId], references: [id])
  participants    CollectiveMissionParticipant[]

  // ─── Lot 22 — Organisation rattachée ─────────────────────────────
  organizationId String?

  @@index([status])
  @@index([type])
  @@index([city])
  @@index([department])
  @@index([region])
  @@index([startsAt])
  @@map("CollectiveMission")
}

model CollectiveMissionParticipant {
  id              String   @id @default(cuid())

  missionId       String
  userId          String

  role            String   @default("CONTRIBUTOR") // ORGANIZER | CONTRIBUTOR | BENEFICIARY | FACILITATOR | OBSERVER
  status          String   @default("JOINED") // JOINED | WAITLISTED | CHECKED_IN | VALIDATED | NO_SHOW | CANCELLED

  joinedAt        DateTime @default(now())
  validatedAt     DateTime?
  validatedById   String?

  hoursValidated  Int?     // minutes réelles validées
  timeReward      Int?     // TIME effectivement reçus
  transactionId   String?

  note            String?

  mission         CollectiveMission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  user            User              @relation(fields: [userId], references: [id])

  @@unique([missionId, userId])
  @@index([missionId])
  @@index([userId])
  @@index([status])
  @@index([role])
  @@map("CollectiveMissionParticipant")
}

// ─── End Lot 19 ───────────────────────────────────────────────────────────

// ─── Lot 13 — Availability & Calendar ────────────────────────────────────────

model AvailabilitySlot {
  id        String   @id @default(cuid())
  userId    String
  type      String   @default("RECURRING") // RECURRING or ONE_OFF
  dayOfWeek Int?     // 1=lundi..7=dimanche (for RECURRING)
  startTime String?  // "18:00"
  endTime   String?  // "20:00"
  startAt   DateTime? // for ONE_OFF
  endAt     DateTime? // for ONE_OFF
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("AvailabilitySlot")
}

// ─── Lot 10 — Gamification ────────────────────────────────────────────────

model Badge {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String
  category    String   @default("general")
  icon        String   @default("award")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  userBadges UserBadge[]
  quests     Quest[]   @relation("QuestBadge")

  @@map("Badge")
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@map("UserBadge")
}

model UserXpEvent {
  id          String   @id @default(cuid())
  userId      String
  type        String
  points      Int
  sourceType  String?
  sourceId    String?
  description String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("UserXpEvent")
}

model AchievementEvent {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  description String?
  metadata    String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("AchievementEvent")
}

model Quest {
  id          String   @id @default(cuid())
  code        String   @unique
  title       String
  description String
  targetType  String    // missions_completed, time_donated, ratings_received, profile_complete, categories_explored
  targetValue Int
  rewardXp    Int      @default(0)
  badgeCode   String?
  badge       Badge?   @relation("QuestBadge", fields: [badgeCode], references: [code])
  isActive    Boolean  @default(true)
  repeatable  Boolean  @default(false)
  createdAt   DateTime @default(now())

  userQuests UserQuest[]

  @@map("Quest")
}

model UserQuest {
  id          String    @id @default(cuid())
  userId      String
  questId     String
  progress    Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  quest Quest @relation(fields: [questId], references: [id])

  user  User  @relation(fields: [userId], references: [id])

  @@unique([userId, questId])
  @@map("UserQuest")
}

// ─── Lot 14 — Discussion sécurisée par booking ────────────────────────────

model BookingMessage {
  id        String   @id @default(cuid())

  bookingId String
  authorId  String?

  content   String
  type      String   @default("USER") // USER, SYSTEM

  isFlagged Boolean  @default(false)
  isHidden  Boolean  @default(false)

  readAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([authorId])
  @@index([createdAt])
}

model MessageReport {
  id         String   @id @default(cuid())

  messageId  String
  reporterId String

  reason     String
  comment    String?
  status     String   @default("OPEN") // OPEN, REVIEWED, DISMISSED

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([messageId])
  @@index([reporterId])
  @@index([status])
}

// ─── Lot 21 — IA Matchmaking assistée ─────────────────────────────────────

model MatchRecommendation {
  id                    String   @id @default(cuid())

  targetType             String   // URGENT_REQUEST | SOLIDARITY_MISSION | COLLECTIVE_MISSION | BOOKING
  targetId               String

  candidateId            String
  facilitatorId          String?

  score                  Float
  skillScore             Float
  locationScore          Float
  availabilityScore      Float
  trustScore             Float
  reciprocityScore       Float
  communityHealthScore   Float

  reasonsJson            String?
  risksJson              String?
  scoreBreakdownJson     String?

  status                 String   @default("PENDING_REVIEW")
  decisionNote           String?
  decidedById            String?
  decidedAt              DateTime?

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  candidate              User            @relation(fields: [candidateId], references: [id])
  feedbacks              MatchFeedback[]

  @@index([targetType, targetId])
  @@index([candidateId])
  @@index([status])
  @@index([score])
  @@map("MatchRecommendation")
}

model MatchFeedback {
  id                   String   @id @default(cuid())

  recommendationId      String
  facilitatorId         String

  decision              String   // GOOD_MATCH | BAD_MATCH | CONTACTED | NOT_AVAILABLE | WRONG_SKILL | OVERUSED | OTHER
  comment               String?

  createdAt             DateTime @default(now())

  recommendation        MatchRecommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  facilitator           User                @relation(fields: [facilitatorId], references: [id])

  @@index([recommendationId])
  @@index([facilitatorId])
  @@map("MatchFeedback")
}

// ─── Lot 22 — Partner Spaces / Organisations ─────────────────────────────

model Organization {
  id              String   @id @default(cuid())

  name            String
  slug            String   @unique
  type            String
  status          String   @default("PENDING_REVIEW")

  description     String?
  shortDescription String?

  logoUrl         String?
  coverImageUrl   String?
  websiteUrl      String?

  city            String?
  department      String?
  region          String?
  country         String?  @default("France")

  contactName     String?
  contactEmail    String?
  contactPhone    String?

  isVerified      Boolean  @default(false)
  verifiedAt      DateTime?
  verifiedById    String?

  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy       User              @relation("OrganizationCreator", fields: [createdById], references: [id])
  members         OrganizationMember[]
  invitations     OrganizationInvitation[]
  pot             OrganizationTimePot?
  impactReports   ImpactReport[]
  programs        OrganizationProgram[]

  @@index([slug])
  @@index([type])
  @@index([status])
  @@index([city])
  @@index([department])
  @@index([region])
  @@index([createdById])
  @@map("Organization")
}

model OrganizationMember {
  id              String   @id @default(cuid())

  organizationId  String
  userId          String

  role            String   @default("MEMBER")
  status          String   @default("ACTIVE") // ACTIVE | INVITED | REMOVED

  invitedById     String?
  joinedAt        DateTime @default(now())
  removedAt       DateTime?

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([role])
  @@index([status])
  @@map("OrganizationMember")
}

model OrganizationInvitation {
  id              String   @id @default(cuid())

  organizationId  String
  email           String?
  tokenHash       String   @unique
  role            String   @default("MEMBER")

  status          String   @default("PENDING") // PENDING | ACCEPTED | EXPIRED | CANCELLED

  invitedById     String
  acceptedById    String?
  acceptedAt      DateTime?
  expiresAt       DateTime

  createdAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@index([status])
  @@map("OrganizationInvitation")
}

model OrganizationTimePot {
  id              String   @id @default(cuid())

  organizationId  String   @unique
  balance         Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions    OrganizationTimePotTransaction[]

  @@map("OrganizationTimePot")
}

model OrganizationTimePotTransaction {
  id              String   @id @default(cuid())

  potId           String
  organizationId  String

  type            String   // DONATION | FUNDING | ADJUSTMENT | REFUND
  amount          Int
  description     String?

  fromUserId      String?
  toUserId        String?

  createdById     String?
  createdAt       DateTime @default(now())

  pot             OrganizationTimePot @relation(fields: [potId], references: [id], onDelete: Cascade)

  @@index([potId])
  @@index([organizationId])
  @@index([type])
  @@index([fromUserId])
  @@index([toUserId])
  @@map("OrganizationTimePotTransaction")
}

// ─── Lot 23 — Impact Reports ──────────────────────────────────────────────

model ImpactReport {
  id                    String   @id @default(cuid())

  organizationId        String
  title                 String
  type                  String   @default("ORGANIZATION_SUMMARY")
  status                String   @default("DRAFT")

  periodStart           DateTime
  periodEnd             DateTime

  summary               String?
  metricsJson           String?
  highlightsJson        String?
  risksJson             String?
  recommendationsJson   String?

  socialValueHourlyRate Int      @default(15)
  socialValueEstimated  Int      @default(0)

  visibility            String   @default("PRIVATE") // PRIVATE | ORGANIZATION | SHARE_LINK | PUBLIC
  publicTokenHash       String?
  publicEnabledAt       DateTime?

  generatedById         String?
  generatedAt           DateTime?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // ─── Lot 24 — Programme ──────────────────────────────────────────
  programId String?
  program   OrganizationProgram? @relation("ProgramImpactReports", fields: [programId], references: [id])

  @@index([organizationId])
  @@index([status])
  @@index([type])
  @@index([periodStart])
  @@index([periodEnd])
  @@map("ImpactReport")
}

// ─── End Lot 23 ───────────────────────────────────────────────────────────

// ─── Lot 23 bis — Wellbeing / Impact humain ─────────────────────────────

model WellbeingSurvey {
  id              String   @id @default(cuid())

  organizationId  String?
  programId       String?
  userId          String

  contextType     String   // ORGANIZATION | PROGRAM | MISSION | SUPPORT_CIRCLE
  contextId       String?

  phase           String   // BEFORE | AFTER | FOLLOW_UP
  status          String   @default("COMPLETED")

  isolationScore      Int?
  supportScore        Int?
  usefulnessScore     Int?
  trustScore          Int?
  contributionScore   Int?

  comment         String?

  scoreTotal      Int?
  scoreAverage    Int?     // scoreAverage100 — 0-100 scale

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
  @@index([programId])
  @@index([userId])
  @@index([contextType, contextId])
  @@index([phase])
  @@map("WellbeingSurvey")
}

// ─── End Lot 23 bis ──────────────────────────────────────────────────────

// ─── Lot 24 — Programmes Organisation ────────────────────────────────────

model OrganizationProgram {
  id                String   @id @default(cuid())
  organizationId    String

  name              String
  slug              String
  type              String   // SENIOR_SOCIAL_LINK | DIGITAL_INCLUSION | YOUTH | CAREGIVER_SUPPORT | NEIGHBORHOOD_SOLIDARITY | OTHER
  status            String   @default("DRAFT") // DRAFT | ACTIVE | COMPLETED | ARCHIVED

  description       String?
  shortDescription  String?

  startDate         DateTime?
  endDate           DateTime?

  targetAudience    String?
  goalsJson         String?
  settingsJson      String?

  createdById       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy         User         @relation("ProgramCreator", fields: [createdById], references: [id])

  participants      ProgramParticipant[]
  impactReports     ImpactReport[] @relation("ProgramImpactReports")

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([type])
  @@index([status])
  @@map("OrganizationProgram")
}

model ProgramParticipant {
  id          String   @id @default(cuid())
  programId   String
  userId      String

  role        String   // SENIOR | HERO | CAREGIVER | FACILITATOR | OBSERVER
  status      String   @default("ACTIVE") // ACTIVE | PAUSED | REMOVED

  joinedAt    DateTime @default(now())
  removedAt   DateTime?

  program     OrganizationProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([programId, userId])
  @@index([programId])
  @@index([userId])
  @@index([role])
  @@index([status])
  @@map("ProgramParticipant")
}

